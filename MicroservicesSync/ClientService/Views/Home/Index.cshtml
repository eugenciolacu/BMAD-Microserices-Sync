@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>
</div>

<div class="mt-4">
    <h2>Administration</h2>

    <div class="mb-3">
        <h4>Reset Client DB</h4>
        <p>Clears all reference data and measurements from this ClientService's SQLite database.
           After reset, use <strong>Pull Reference Data</strong> below (or restart the container) to repopulate reference data.</p>
        <button id="btnReset" class="btn btn-danger" onclick="resetClient()">Reset Client DB</button>
        <div id="resetResult" class="mt-2"></div>
    </div>

    <div class="mb-3">
        <h4>Pull Reference Data</h4>
        <p>Manually pulls reference data from ServerService into this ClientService's local database.
           Only works when the local DB is empty (run <strong>Reset Client DB</strong> first if needed).</p>
        <button id="btnPull" class="btn btn-primary" onclick="pullReferenceData()">Pull Reference Data</button>
        <div id="pullResult" class="mt-2"></div>
    </div>
</div>

<div class="mt-4">
    <h2>Sync Scenario Controls</h2>

    <div class="mb-3">
        <h4>Generate Measurements</h4>
        <p>Generates the configured number of measurements (<code>SyncOptions:MeasurementsPerClient</code>) for this client instance,
           tagged with this client's identity (<code>ClientIdentity:UserId</code>).</p>
        <p><em>Prerequisites: reset to baseline + pull reference data must be completed on this instance before generating.</em></p>
        <button id="btnGenerate" onclick="generateMeasurements()" class="btn btn-primary">Generate Measurements</button>
        <div id="generateResult" class="mt-2"></div>
    </div>

    <div class="mb-3">
        <h4>Push Measurements to ServerService</h4>
        <p>Pushes all unsynced local measurements (where <code>SyncedAt == null</code>) to ServerService
           in batched, transactional form. The server applies all batches in a single transaction.</p>
        <p><em>Prerequisites: measurements must be generated on this instance first.</em></p>
        <button id="btnPush" onclick="pushMeasurements()" class="btn btn-success">Push Measurements</button>
        <div id="pushResult" class="mt-2"></div>
    </div>

    <div class="mb-3">
        <h4>Pull Consolidated Measurements from ServerService</h4>
        <p>Retrieves the full measurement set from ServerService and applies any new (missing) measurements
           to this client's local database in batched, transactional form. Either all new measurements
           are applied or none (on error).</p>
        <p><em>Prerequisites: at least one push must have been completed (by any client) before pulling.</em></p>
        <button id="btnPullMeasurements" onclick="pullMeasurements()" class="btn btn-info">Pull Measurements</button>
        <div id="pullMeasurementsResult" class="mt-2"></div>
    </div>

    <div class="mb-3">
        <h4>Verify Convergence</h4>
        <p>Checks whether this client's local measurement count matches ServerService's total count.
           Run after a completed pull to confirm convergence.</p>
        <button id="btnVerifyConvergence" onclick="verifyConvergence()" class="btn btn-secondary">Verify Convergence</button>
        <div id="verifyConvergenceResult" class="mt-2"></div>
    </div>
</div>

<script>
    function resetClient() {
        if (!confirm('Are you sure? This will delete all measurements and all reference data.\nYou will need to pull reference data again or restart the container.')) return;
        document.getElementById('btnReset').disabled = true;
        fetch('/api/v1/admin/reset', { method: 'POST' })
            .then(async r => {
                const data = await r.json();
                if (!r.ok) throw new Error(data.message || 'Request failed (' + r.status + ')');
                return data;
            })
            .then(data => {
                const el = document.createElement('div');
                el.className = 'alert alert-success mt-2';
                el.textContent = data.message;
                const box = document.getElementById('resetResult');
                box.innerHTML = '';
                box.appendChild(el);
            })
            .catch(err => {
                const el = document.createElement('div');
                el.className = 'alert alert-danger mt-2';
                el.textContent = 'Reset failed: ' + (err.message || err);
                const box = document.getElementById('resetResult');
                box.innerHTML = '';
                box.appendChild(el);
            })
            .finally(() => { document.getElementById('btnReset').disabled = false; });
    }

    function pullReferenceData() {
        document.getElementById('btnPull').disabled = true;
        fetch('/api/v1/admin/pull-reference-data', { method: 'POST' })
            .then(async r => {
                const data = await r.json();
                if (!r.ok) throw new Error(data.message || 'Request failed (' + r.status + ')');
                return data;
            })
            .then(data => {
                const el = document.createElement('div');
                el.className = 'alert alert-success mt-2';
                el.textContent = data.message;
                const box = document.getElementById('pullResult');
                box.innerHTML = '';
                box.appendChild(el);
            })
            .catch(err => {
                const el = document.createElement('div');
                el.className = 'alert alert-danger mt-2';
                el.textContent = 'Pull failed: ' + (err.message || err);
                const box = document.getElementById('pullResult');
                box.innerHTML = '';
                box.appendChild(el);
            })
            .finally(() => { document.getElementById('btnPull').disabled = false; });
    }

    async function generateMeasurements() {
        document.getElementById('btnGenerate').disabled = true;
        fetch('/api/v1/measurements/generate', { method: 'POST' })
            .then(async r => {
                const data = await r.json();
                if (!r.ok) throw new Error(data.message || 'Request failed (' + r.status + ')');
                return data;
            })
            .then(data => {
                const el = document.createElement('div');
                el.className = 'alert alert-success mt-2';
                el.textContent = data.message;
                const box = document.getElementById('generateResult');
                box.innerHTML = '';
                box.appendChild(el);
            })
            .catch(err => {
                const el = document.createElement('div');
                el.className = 'alert alert-danger mt-2';
                el.textContent = 'Generation failed: ' + (err.message || err);
                const box = document.getElementById('generateResult');
                box.innerHTML = '';
                box.appendChild(el);
            })
            .finally(() => { document.getElementById('btnGenerate').disabled = false; });
    }

    function pushMeasurements() {
        document.getElementById('btnPush').disabled = true;
        fetch('/api/v1/measurements/push', { method: 'POST' })
            .then(async r => {
                const data = await r.json();
                if (!r.ok) throw new Error(data.message || 'Request failed (' + r.status + ')');
                return data;
            })
            .then(data => {
                const el = document.createElement('div');
                el.className = 'alert alert-success mt-2';
                el.textContent = data.message;
                const box = document.getElementById('pushResult');
                box.innerHTML = '';
                box.appendChild(el);
            })
            .catch(err => {
                const el = document.createElement('div');
                el.className = 'alert alert-danger mt-2';
                el.textContent = 'Push failed: ' + (err.message || err);
                const box = document.getElementById('pushResult');
                box.innerHTML = '';
                box.appendChild(el);
            })
            .finally(() => { document.getElementById('btnPush').disabled = false; });
    }

    function pullMeasurements() {
        document.getElementById('btnPullMeasurements').disabled = true;
        fetch('/api/v1/measurements/pull', { method: 'POST' })
            .then(async r => {
                const data = await r.json();
                if (!r.ok) throw new Error(data.message || 'Request failed (' + r.status + ')');
                return data;
            })
            .then(data => {
                const el = document.createElement('div');
                el.className = 'alert alert-success mt-2';
                el.textContent = data.message;
                const box = document.getElementById('pullMeasurementsResult');
                box.innerHTML = '';
                box.appendChild(el);
            })
            .catch(err => {
                const el = document.createElement('div');
                el.className = 'alert alert-danger mt-2';
                el.textContent = 'Pull failed: ' + (err.message || err);
                const box = document.getElementById('pullMeasurementsResult');
                box.innerHTML = '';
                box.appendChild(el);
            })
            .finally(() => { document.getElementById('btnPullMeasurements').disabled = false; });
    }

    function verifyConvergence() {
        document.getElementById('btnVerifyConvergence').disabled = true;
        const localFetch = fetch('/api/v1/measurements/count').then(async r => {
            if (!r.ok) throw new Error('Local count failed (' + r.status + ')');
            return r.json();
        });
        const serverFetch = fetch('/api/v1/measurements/server-count').then(async r => {
            if (!r.ok) throw new Error('Server count failed (' + r.status + ')');
            return r.json();
        });
        Promise.all([localFetch, serverFetch])
            .then(([localData, serverData]) => {
                const localCount = localData.count;
                const serverCount = serverData.count;
                const el = document.createElement('div');
                if (localCount === 0 && serverCount === 0) {
                    el.className = 'alert alert-secondary mt-2';
                    el.textContent = 'No data yet: both client and server have 0 measurements. Run the scenario first.';
                } else {
                    const matched = localCount === serverCount;
                    el.className = matched ? 'alert alert-success mt-2' : 'alert alert-warning mt-2';
                    el.textContent = matched
                        ? `\u2713 Converged: this client has ${localCount} measurements, server has ${serverCount}.`
                        : `\u26a0 Not yet converged: this client has ${localCount} measurements, server has ${serverCount}. Run Pull Measurements first.`;
                }
                const box = document.getElementById('verifyConvergenceResult');
                box.innerHTML = '';
                box.appendChild(el);
            })
            .catch(err => {
                const el = document.createElement('div');
                el.className = 'alert alert-danger mt-2';
                el.textContent = 'Verify failed: ' + (err.message || err);
                const box = document.getElementById('verifyConvergenceResult');
                box.innerHTML = '';
                box.appendChild(el);
            })
            .finally(() => { document.getElementById('btnVerifyConvergence').disabled = false; });
    }
</script>
