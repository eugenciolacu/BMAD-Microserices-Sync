@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>
</div>

<div class="mt-4">
    <h2>Sync Run Summary</h2>
    <p>Recent sync push and pull operations recorded by ServerService. Newest first. Auto-loads on page open.</p>

    <div class="mb-2">
        <label for="filterUserId">Filter by User:</label>
        <select id="filterUserId" class="form-select form-select-sm d-inline-block w-auto">
            <option value="">All Users</option>
            <!-- Options populated by JavaScript on load -->
        </select>
        <label for="filterRunType" class="ms-2">Run Type:</label>
        <select id="filterRunType" class="form-select form-select-sm d-inline-block w-auto">
            <option value="">All</option>
            <option value="push">Push</option>
            <option value="pull">Pull</option>
        </select>
        <button class="btn btn-sm btn-outline-secondary ms-2" onclick="loadSyncRuns()">Refresh</button>
    </div>

    <div id="syncRunsResult">
        <p class="text-muted">Loading...</p>
    </div>
</div>

<div class="mt-4">
    <h2>Administration</h2>
    <p>Reset the ServerService database to the clean baseline state (all measurements deleted, reference data re-seeded).</p>
    <button id="btnReset" class="btn btn-danger" onclick="resetServer()">Reset to Baseline</button>
    <div id="resetResult" class="mt-2"></div>
</div>

<div class="mt-4">
    <h2>Edge-Case Scenario: 3-Client Reduced-Volume Batching</h2>
    <p>
        This edge-case variant uses <strong>3 clients × 5 measurements</strong> with <code>SyncOptions:BatchSize=2</code>
        to stress-test batching with uneven batch counts (5 ÷ 2 = 2 full batches + 1 partial batch).
        Run it from a clean baseline to confirm all-or-nothing transactional guarantees hold
        even with truncated final batches.
    </p>

    <h5>Steps to Run</h5>
    <ol>
        <li>Ensure the system is running: <code>docker-compose up</code> (from <code>MicroservicesSync/</code> folder).</li>
        <li>Reset all 5 clients (or just clients 1–3) via <strong>Reset Client DB</strong> on each ClientService UI.</li>
        <li>Pull reference data on clients 1–3 via <strong>Pull Reference Data</strong> (Administration section on each client).</li>
        <li>
            Set <code>SyncOptions__MeasurementsPerClient=5</code> and <code>SyncOptions__BatchSize=2</code> for clients 1–3
            via <code>docker-compose.override.yml</code> or by direct environment variable override.
            <br /><em>Alternative (no restart):</em> The default <code>MeasurementsPerClient=10, BatchSize=5</code> also demonstrates
            the scenario — use <code>MeasurementsPerClient=5</code> and <code>BatchSize=2</code> for maximum batch-remainder stress-testing.
        </li>
        <li>Generate measurements on clients 1–3 only (click <strong>Generate Measurements</strong> on each).</li>
        <li>Push from each of clients 1–3 (click <strong>Push Measurements</strong>).</li>
        <li>Verify the Measurements grid on this ServerService page shows <strong>15 records</strong> (3 clients × 5 measurements each).</li>
        <li>Pull on clients 1–3 (click <strong>Pull Measurements</strong>).</li>
        <li>Click <strong>Verify Convergence</strong> on each of clients 1–3 — each should report 15 local measurements matching the server's 15.</li>
        <li>(Optional) Clients 4 and 5 remain at baseline with 0 measurements, confirming isolation.</li>
    </ol>

    <h5>Verify Convergence</h5>
    <p>
        After completing all pushes and pulls, each participating client's local measurement count should match the server total (15).
        Use the <strong>Verify Convergence</strong> button on each ClientService home page to confirm.
        Links to measurement grids:
    </p>
    <ul>
        <li><a href="/Measurements">ServerService Measurements Grid</a></li>
    </ul>

    <h5>Unhandled-Error Check</h5>
    <p>No 500 errors should appear in any client or server logs. All batches should commit cleanly.</p>
</div>

<div class="mt-4">
    <section>
        <h3>Full Scenario Cycle — Repeatable Runs</h3>
        <p>
            Run the complete standard scenario (<strong>5 clients × 10 measurements</strong>) from a clean baseline,
            repeating as many times as needed to build confidence in reliability and repeatability.
            Each iteration uses the default <code>SyncOptions__MeasurementsPerClient=10</code> and
            <code>SyncOptions__BatchSize=5</code> configuration already in <code>docker-compose.yml</code>.
        </p>

        <h5>Steps for One Complete Cycle</h5>
        <ol>
            <li>Click <strong>Reset to Baseline</strong> on this ServerService page. <em>(Clears all Measurements; re-seeds reference data — 0 measurements.)</em></li>
            <li>On each of the 5 ClientService UIs: click <strong>Reset Client DB</strong>. <em>(Clears SQLite database. No ref data yet.)</em></li>
            <li>On each of the 5 ClientService UIs: click <strong>Pull Reference Data</strong> in the Administration section. <em>(Re-seeds Buildings, Rooms, Surfaces, Cells, Users from ServerService.)</em></li>
            <li>On each of the 5 ClientService UIs: click <strong>Generate Measurements</strong>. <em>(Creates 10 new measurements per client with fresh GUIDs — no conflict with previous runs.)</em></li>
            <li>On each of the 5 ClientService UIs: click <strong>Push Measurements</strong>. <em>(Sends all local measurements to ServerService in batches of 5, inside a single transaction.)</em></li>
            <li>Verify the Measurements grid on this ServerService page shows <strong>50 records</strong> (5 clients × 10 each).</li>
            <li>On each of the 5 ClientService UIs: click <strong>Pull Measurements</strong>. <em>(Pulls all 50 measurements from ServerService into each client in batches of 5, inside a single transaction.)</em></li>
            <li>On each of the 5 ClientService UIs: click <strong>Verify Convergence</strong>. <em>(Each client should report 50 local measurements matching the server's 50.)</em></li>
            <li>To repeat: return to Step 1. Every new Generate creates unique GUIDs so no ID conflicts occur across runs.</li>
        </ol>

        <p>
            <strong>Why repeats are clean:</strong> Each run generates measurements with new GUIDs (<code>Guid.NewGuid()</code>),
            so repeated cycles from a fresh reset never produce duplicate IDs. The transactional push and pull ensure
            all-or-nothing semantics — partial failures leave no residue.
        </p>

        <p>
            <strong>Edge-case repeat note:</strong> For the 3-client edge-case variant (see the section above), the same
            cycle applies — only reset, generate, push, and pull on clients 1–3. Clients 4 and 5 remain untouched.
        </p>
    </section>
</div>

<script>
    function resetServer() {
        if (!confirm('Are you sure? This will delete all measurements and re-seed reference data.')) return;
        document.getElementById('btnReset').disabled = true;
        fetch('/api/v1/admin/reset', { method: 'POST' })
            .then(async r => {
                const data = await r.json();
                if (!r.ok) throw new Error(data.message || 'Request failed (' + r.status + ')');
                return data;
            })
            .then(data => {
                const el = document.createElement('div');
                el.className = 'alert alert-success mt-2';
                el.textContent = data.message;
                const box = document.getElementById('resetResult');
                box.innerHTML = '';
                box.appendChild(el);
            })
            .catch(err => {
                const el = document.createElement('div');
                el.className = 'alert alert-danger mt-2';
                el.textContent = 'Reset failed: ' + (err.message || err);
                const box = document.getElementById('resetResult');
                box.innerHTML = '';
                box.appendChild(el);
            })
            .finally(() => { document.getElementById('btnReset').disabled = false; });
    }

    function loadSyncRuns() {
        const userId = document.getElementById('filterUserId').value;
        const runType = document.getElementById('filterRunType').value;
        let url = '/api/v1/sync-runs?limit=50';
        if (userId) url += '&userId=' + encodeURIComponent(userId);
        if (runType) url += '&runType=' + encodeURIComponent(runType);

        fetch(url)
            .then(r => {
                if (!r.ok) throw new Error('Server error (' + r.status + ')');
                return r.json();
            })
            .then(data => {
                const runs = data.runs || [];
                if (runs.length === 0) {
                    document.getElementById('syncRunsResult').innerHTML =
                        '<p class="text-muted">No sync runs recorded yet. Run a Push or Pull scenario first.</p>';
                    return;
                }
                let html = '<table class="table table-sm table-striped table-bordered">'
                    + '<thead><tr><th>Timestamp (UTC)</th><th>Type</th><th>User</th><th>Count</th><th>Status</th><th>Error</th></tr></thead><tbody>';
                for (const r of runs) {
                    const statusClass = r.status === 'success' ? 'text-success' : 'text-danger fw-bold';
                    const error = r.errorMessage ? '<span class="text-danger">' + escapeHtml(r.errorMessage) + '</span>' : '';
                    html += `<tr>
                        <td>${escapeHtml(r.occurredAt)}</td>
                        <td>${escapeHtml(r.runType)}</td>
                        <td>${escapeHtml(r.username || r.userId)}</td>
                        <td>${escapeHtml(String(r.measurementCount))}</td>
                        <td class="${statusClass}">${escapeHtml(r.status)}</td>
                        <td>${error}</td>
                    </tr>`;
                }
                html += '</tbody></table>';
                document.getElementById('syncRunsResult').innerHTML = html;

                // Populate user filter dropdown from data (deduplicate)
                const userSelect = document.getElementById('filterUserId');
                const existingValues = Array.from(userSelect.options).map(o => o.value);
                for (const r of runs) {
                    if (r.userId && r.userId !== '00000000-0000-0000-0000-000000000000' && !existingValues.includes(r.userId)) {
                        const opt = document.createElement('option');
                        opt.value = r.userId;
                        opt.textContent = r.username || r.userId;
                        userSelect.appendChild(opt);
                        existingValues.push(r.userId);
                    }
                }
            })
            .catch(err => {
                document.getElementById('syncRunsResult').innerHTML =
                    '<div class="alert alert-danger">Failed to load sync runs: ' + escapeHtml(err.message || String(err)) + '</div>';
            });
    }

    function escapeHtml(str) {
        if (str === null || str === undefined) return '';
        return String(str)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#039;');
    }

    // Auto-load on page open
    document.addEventListener('DOMContentLoaded', loadSyncRuns);
</script>
