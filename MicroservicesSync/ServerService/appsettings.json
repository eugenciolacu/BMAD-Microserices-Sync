{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "SyncOptions": {
    "BatchSize": 5,
    // MeasurementsPerClient is a client-side generation parameter (used by ClientService).
    // It is declared here so ServerService shares a single SyncOptions schema and operators
    // can observe or document the expected value alongside BatchSize in one place.
    "MeasurementsPerClient": 10
  }
}
